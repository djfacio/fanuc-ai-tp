{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.fanuc-ai-tp/schemas/motion-application-spec.schema.json",
  "title": "FANUC Motion Application Workflow Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "applicationName",
    "programName",
    "phase",
    "purpose",
    "cellContext",
    "policy",
    "resources",
    "motionPlan",
    "safety",
    "evidence",
    "generation"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "applicationName": { "type": "string", "minLength": 1 },
    "programName": {
      "type": "string",
      "pattern": "^(?:A_[A-Z0-9_]{1,30}|AI_[A-Z0-9_]{1,29})$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "planning",
        "simulation-ready",
        "generation-ready",
        "generated",
        "uploaded",
        "operator-released",
        "released"
      ]
    },
    "purpose": { "type": "string", "minLength": 1 },
    "cellContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controller", "robot", "workcell", "process", "payloadName"],
      "properties": {
        "controller": { "type": "string", "minLength": 1 },
        "robot": { "type": "string", "minLength": 1 },
        "workcell": { "type": "string", "minLength": 1 },
        "process": { "type": "string", "minLength": 1 },
        "payloadName": { "type": "string", "minLength": 1 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cellMapPolicy", "motionAuthority", "humanReviewRequired", "productionOverwriteAllowed"],
      "properties": {
        "cellMapPolicy": { "type": "string", "minLength": 1 },
        "motionAuthority": {
          "type": "string",
          "enum": ["not-authorized", "reviewed-motion-template", "reviewed-application"]
        },
        "humanReviewRequired": { "type": "boolean" },
        "productionOverwriteAllowed": { "type": "boolean" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["userFrame", "userTool", "payload", "points", "io", "registers", "calls"],
      "properties": {
        "userFrame": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "name", "source", "verified"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "name": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "verified": { "type": "boolean" }
          }
        },
        "userTool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "name", "source", "verified"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "name": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "verified": { "type": "boolean" }
          }
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "name", "source", "verified"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "name": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "verified": { "type": "boolean" }
          }
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "source", "verified", "touchupRequired"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "source": {
                "type": "string",
                "enum": ["taught-point", "position-register", "fixture-reference", "imported-reviewed"]
              },
              "verified": { "type": "boolean" },
              "touchupRequired": { "type": "boolean" }
            }
          }
        },
        "io": { "type": "array" },
        "registers": { "type": "array" },
        "calls": { "type": "array" }
      }
    },
    "motionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["motionTypes", "speedPolicy", "terminationPolicy", "approachRetract", "clearancePolicy", "recoveryPlan", "motionSequence"],
      "properties": {
        "motionTypes": { "type": "array", "minItems": 1 },
        "speedPolicy": { "type": "string", "minLength": 1 },
        "terminationPolicy": { "type": "string", "minLength": 1 },
        "approachRetract": { "type": "string", "minLength": 1 },
        "clearancePolicy": { "type": "string", "minLength": 1 },
        "recoveryPlan": { "type": "string", "minLength": 1 },
        "motionSequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stepName", "motionType", "target", "speed", "termination"],
            "properties": {
              "stepName": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]{0,30}$"
              },
              "motionType": {
                "type": "string",
                "enum": ["J", "L"]
              },
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "number", "name", "source", "verified"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["position-register"]
                  },
                  "number": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9999
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source": {
                    "type": "string",
                    "minLength": 1
                  },
                  "verified": {
                    "type": "boolean"
                  }
                }
              },
              "speed": {
                "type": "object",
                "additionalProperties": false,
                "required": ["value", "unit"],
                "properties": {
                  "value": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "unit": {
                    "type": "string",
                    "enum": ["%", "mm/sec", "cm/min", "deg/sec"]
                  }
                }
              },
              "termination": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["FINE", "CNT"]
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100
                  }
                }
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "ioSequence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stepName", "position", "signal", "state", "verified"],
            "properties": {
              "stepName": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]{0,30}$"
              },
              "position": {
                "type": "string",
                "enum": ["before", "after"]
              },
              "signal": {
                "type": "string",
                "pattern": "^(DO|RO)\\[[1-9][0-9]*\\]$"
              },
              "state": {
                "type": "boolean"
              },
              "source": {
                "type": "string"
              },
              "verified": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "positionArchitecture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy", "calcProgram", "prFamilies", "offsetPrs", "derivedPrs", "inlineOffsetPolicy", "breadcrumb"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["direct-reviewed-prs", "explicit-calculated-prs", "inline-offsets"]
            },
            "notes": {
              "type": "string"
            },
            "calcProgram": {
              "type": "object",
              "additionalProperties": false,
              "required": ["required", "programName", "callBeforeMotion", "verified"],
              "properties": {
                "required": { "type": "boolean" },
                "programName": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]{0,31}$"
                },
                "callBeforeMotion": { "type": "boolean" },
                "verified": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            },
            "prFamilies": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["familyName", "start", "size", "purpose", "owner", "verified"],
                "properties": {
                  "familyName": { "type": "string", "minLength": 1 },
                  "start": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "size": { "type": "integer", "minimum": 1, "maximum": 100 },
                  "purpose": { "type": "string", "minLength": 1 },
                  "owner": { "type": "string", "minLength": 1 },
                  "verified": { "type": "boolean" },
                  "notes": { "type": "string" }
                }
              }
            },
            "fixedPrs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["number", "name", "role", "owner", "verified"],
                "properties": {
                  "number": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "name": { "type": "string", "minLength": 1 },
                  "role": {
                    "type": "string",
                    "enum": ["home", "safe", "approach", "process", "retract", "intermediate", "other"]
                  },
                  "owner": { "type": "string", "minLength": 1 },
                  "verified": { "type": "boolean" },
                  "notes": { "type": "string" }
                }
              }
            },
            "offsetPrs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["number", "name", "owner", "source", "aiMayPopulate", "verified"],
                "properties": {
                  "number": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "name": { "type": "string", "minLength": 1 },
                  "owner": { "type": "string", "minLength": 1 },
                  "source": { "type": "string", "minLength": 1 },
                  "aiMayPopulate": { "type": "boolean" },
                  "verified": { "type": "boolean" },
                  "zeroingMethod": {
                    "type": "string",
                    "enum": ["not-required", "lpos-minus-lpos", "manual-existing", "other-reviewed"]
                  },
                  "notes": { "type": "string" }
                }
              }
            },
            "derivedPrs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["number", "name", "role", "sourceBasePr", "sourceOffsetPr", "writer", "availableForPendantMoveTo", "verified"],
                "properties": {
                  "number": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "name": { "type": "string", "minLength": 1 },
                  "role": {
                    "type": "string",
                    "enum": ["approach", "process", "safe", "retract", "intermediate", "temp", "other"]
                  },
                  "sourceBasePr": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "sourceOffsetPr": { "type": "integer", "minimum": 1, "maximum": 9999 },
                  "writer": { "type": "string", "minLength": 1 },
                  "availableForPendantMoveTo": { "type": "boolean" },
                  "verified": { "type": "boolean" },
                  "notes": { "type": "string" }
                }
              }
            },
            "inlineOffsetPolicy": {
              "type": "object",
              "additionalProperties": false,
              "required": ["defaultAllowed", "exceptions"],
              "properties": {
                "defaultAllowed": { "type": "boolean" },
                "exceptions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["stepName", "modifier", "reason", "reviewed"],
                    "properties": {
                      "stepName": {
                        "type": "string",
                        "pattern": "^[A-Z][A-Z0-9_]{0,30}$"
                      },
                      "modifier": {
                        "type": "string",
                        "enum": ["Offset,PR[]", "Tool_Offset,PR[]"]
                      },
                      "reason": { "type": "string", "minLength": 1 },
                      "reviewed": { "type": "boolean" }
                    }
                  }
                }
              }
            },
            "breadcrumb": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "register", "comment", "assignmentPosition", "semantics", "requiredForEveryMotion"],
              "properties": {
                "enabled": { "type": "boolean" },
                "register": { "type": "integer", "minimum": 1, "maximum": 9999 },
                "comment": { "type": "string", "minLength": 1 },
                "assignmentPosition": {
                  "type": "string",
                  "enum": ["after-motion", "before-motion", "both"]
                },
                "semantics": {
                  "type": "string",
                  "enum": ["last-motion-statement-advanced-past", "commanded-target", "actual-position-only-fine"]
                },
                "requiredForEveryMotion": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dcsReviewed", "interlocksReviewed", "operatorLocationReviewed", "faultHandlingReviewed", "noControllerConfigWrites"],
      "properties": {
        "dcsReviewed": { "type": "boolean" },
        "interlocksReviewed": { "type": "boolean" },
        "operatorLocationReviewed": { "type": "boolean" },
        "faultHandlingReviewed": { "type": "boolean" },
        "noControllerConfigWrites": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roboguideRequired", "roboguidePlan", "operatorRunPlan", "snapshotPlan", "acceptanceCriteria"],
      "properties": {
        "roboguideRequired": { "type": "boolean" },
        "roboguidePlan": { "type": "string", "minLength": 1 },
        "operatorRunPlan": { "type": "string", "minLength": 1 },
        "snapshotPlan": { "type": "string", "minLength": 1 },
        "acceptanceCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "mode", "templateId"],
      "properties": {
        "allowed": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["not-authorized", "reviewed-template-only", "reviewed-motion-template"]
        },
        "templateId": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}

{
  "programName": "AI_CELLCHK",
  "intent": "No-motion cell preflight checklist before future AI-assisted generated workflows.",
  "safety": {
    "motionAllowed": false,
    "requiresHumanReview": true,
    "notes": "No motion. No IO writes. Writes one marker register and displays operator checklist comments."
  },
  "operations": [
    {
      "type": "message",
      "text": "AI CELL CHECK"
    },
    {
      "type": "registerWrite",
      "register": 97,
      "value": 20260512
    },
    {
      "type": "diagnosticCheck",
      "name": "CELL",
      "text": "Verify area clear"
    },
    {
      "type": "diagnosticCheck",
      "name": "TOOL",
      "text": "Verify EOAT ready"
    },
    {
      "type": "diagnosticCheck",
      "name": "PART",
      "text": "Verify part state"
    },
    {
      "type": "diagnosticCheck",
      "name": "CNC",
      "text": "Verify machine state"
    },
    {
      "type": "diagnosticCheck",
      "name": "RECOVERY",
      "text": "Verify safe recovery path"
    }
  ],
  "verification": {
    "roboguideRequired": false,
    "manualT1Required": true,
    "notes": "Verify message, R[97] marker, checklist comments, and no motion."
  }
}
